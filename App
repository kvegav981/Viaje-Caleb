<!DOCTYPE html>

<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1,maximum-scale=1">
<title>🕷️ La Misión de Caleb</title>
<link href="https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;700;800;900&display=swap" rel="stylesheet">
<style>
:root{
  --red:#D32F2F;--red2:#B71C1C;--blue:#1565C0;--blue2:#0D47A1;
  --web:#fff;--bg:#0D47A1;--card:#fff;--muted:#546E7A;--light:#CFD8DC;
  --yellow:#FFD54F;--darkbg:#1a1a2e;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Nunito',sans-serif;background:#0D47A1;min-height:100vh;overflow-x:hidden;}

/* ── HEADER ── */
.hdr{
background:linear-gradient(160deg,#B71C1C 0%,#D32F2F 50%,#C62828 100%);
padding:0;position:relative;overflow:hidden;
}
/* Web pattern overlay */
.hdr::before{
content:’’;position:absolute;inset:0;
background-image:
repeating-linear-gradient(0deg,transparent,transparent 28px,rgba(255,255,255,.07) 28px,rgba(255,255,255,.07) 29px),
repeating-linear-gradient(90deg,transparent,transparent 28px,rgba(255,255,255,.07) 28px,rgba(255,255,255,.07) 29px);
pointer-events:none;
}
.hdr-inner{padding:14px 15px 12px;position:relative;z-index:1;}
.hdr-top{display:flex;align-items:center;gap:10px;}
.spidey-logo{font-size:42px;animation:spideyBob 2s ease-in-out infinite;}
@keyframes spideyBob{0%,100%{transform:translateY(0)}50%{transform:translateY(-5px)}}
.hdr-text .htitle{font-family:‘Fredoka One’,cursive;font-size:22px;color:#fff;text-shadow:2px 3px 0 rgba(0,0,0,.4);}
.hdr-text .hsub{font-size:11px;color:rgba(255,255,255,.85);font-weight:800;margin-top:2px;}
/* Hanging web thread */
.web-thread{
position:absolute;top:0;right:24px;width:2px;
background:linear-gradient(to bottom,rgba(255,255,255,.6),rgba(255,255,255,.1));
animation:threadLen 3s ease-in-out infinite;
transform-origin:top center;
}
@keyframes threadLen{0%,100%{height:50px}50%{height:70px}}
.web-spidey-hang{position:absolute;right:16px;font-size:22px;animation:hang 3s ease-in-out infinite;}
@keyframes hang{0%,100%{top:50px}50%{top:70px}}

/* ── TABS ── */
.tabs{display:flex;background:#B71C1C;position:sticky;top:0;z-index:30;box-shadow:0 3px 12px rgba(0,0,0,.4);overflow-x:auto;}
.tab{flex:1;min-width:56px;padding:7px 3px;border:none;background:none;cursor:pointer;font-family:‘Nunito’,sans-serif;font-size:9.5px;font-weight:800;color:rgba(255,255,255,.5);transition:all .2s;display:flex;flex-direction:column;align-items:center;gap:2px;}
.tab .ti{font-size:20px;}
.tab.active{color:#FFD54F;border-bottom:3px solid #FFD54F;}

/* ── SECTIONS ── */
.sec{display:none;padding:12px;}
.sec.active{display:block;}
.slbl{font-family:‘Fredoka One’,cursive;font-size:18px;color:#B71C1C;margin-bottom:9px;}
.card{background:#fff;border-radius:18px;overflow:hidden;margin-bottom:13px;box-shadow:0 6px 24px rgba(0,0,0,.25);}

/* ── SETUP PANEL ── */
.setup-panel{padding:14px;background:#FFEBEE;border-bottom:3px solid #EF9A9A;position:relative;overflow:hidden;}
.setup-panel::after{
content:‘🕸️’;position:absolute;right:10px;bottom:-4px;font-size:40px;opacity:.12;
}
.setup-title{font-family:‘Fredoka One’,cursive;font-size:15px;color:#B71C1C;margin-bottom:8px;}
.setup-row{display:flex;gap:10px;}
.fg{flex:1;}
.fg label{display:block;font-size:10px;font-weight:800;color:#C62828;text-transform:uppercase;letter-spacing:.4px;margin-bottom:3px;}
.fg input{border:2px solid #EF9A9A;border-radius:9px;padding:8px 9px;font-family:‘Nunito’,sans-serif;font-size:14px;font-weight:800;width:100%;outline:none;background:#fff;transition:border .2s;color:#1a1a1a;}
.fg input:focus{border-color:#D32F2F;}

/* ── MAP ── */
.map-wrap{position:relative;overflow:hidden;}
#mapCanvas{display:block;width:100%;touch-action:auto;}

/* ── GO BUTTON ── */
.btn-go{
display:block;margin:12px 14px 0;border:none;border-radius:14px;padding:14px;
font-family:‘Fredoka One’,cursive;font-size:18px;cursor:pointer;transition:transform .15s;
width:calc(100% - 28px);
background:linear-gradient(135deg,#D32F2F,#B71C1C);
color:#fff;box-shadow:0 5px 18px rgba(183,28,28,.5);
letter-spacing:.5px;
position:relative;overflow:hidden;
}
.btn-go::before{content:‘🕷️’;position:absolute;left:16px;top:50%;transform:translateY(-50%);font-size:20px;}
.btn-go::after{content:‘🕷️’;position:absolute;right:16px;top:50%;transform:translateY(-50%);font-size:20px;}
.btn-go:active{transform:scale(.96);}

/* ── KID PROGRESS ── */
.kid-progress{padding:14px;background:#FFEBEE;border-top:3px solid #EF9A9A;position:relative;}
/* web corner decorations */
.kid-progress::before{content:‘🕸️’;position:absolute;top:6px;right:10px;font-size:30px;opacity:.15;}

.kid-time-row{display:flex;gap:8px;margin-bottom:12px;}
.kid-time-box{flex:1;background:#fff;border-radius:14px;padding:10px 6px;text-align:center;box-shadow:0 3px 10px rgba(183,28,28,.15);border:2px solid #FFCDD2;}
.kid-time-box .big-icon{font-size:28px;display:block;margin-bottom:2px;}
.kid-time-box .time-val{font-family:‘Fredoka One’,cursive;font-size:17px;color:#B71C1C;}
.kid-time-box .time-lbl{font-size:9px;font-weight:800;color:#90A4AE;text-transform:uppercase;display:block;margin-top:1px;}
.kid-time-box.paused .time-val{color:#1565C0;}

/* PROGRESS BAR */
.big-prog-wrap{margin-bottom:10px;}
.big-prog-label{font-family:‘Fredoka One’,cursive;font-size:15px;color:#B71C1C;margin-bottom:6px;text-align:center;}
.big-prog-track{
background:#FFCDD2;border-radius:30px;height:46px;position:relative;overflow:hidden;
border:3px solid #EF9A9A;
}
.big-prog-fill{
height:100%;border-radius:30px;min-width:46px;
background:linear-gradient(90deg,#D32F2F,#FF6F00);
transition:width .8s ease;position:relative;
}
/* Web pattern on fill */
.big-prog-fill::after{
content:’’;position:absolute;inset:0;
background-image:repeating-linear-gradient(45deg,transparent,transparent 6px,rgba(255,255,255,.1) 6px,rgba(255,255,255,.1) 7px);
border-radius:30px;
}
.big-prog-car{position:absolute;right:-4px;top:50%;transform:translateY(-50%);font-size:36px;filter:drop-shadow(1px 2px 4px rgba(0,0,0,.3));z-index:1;}

/* MILESTONE STARS — spider-themed */
.stars-row{display:flex;justify-content:space-around;margin-bottom:12px;}
.star-ms{display:flex;flex-direction:column;align-items:center;gap:3px;}
.star-ms .s-icon{font-size:36px;filter:grayscale(1) opacity(.25);transition:all .5s;}
.star-ms .s-icon.lit{filter:none;animation:webPop .5s cubic-bezier(.68,-.55,.27,1.55);}
@keyframes webPop{0%{transform:scale(0) rotate(-20deg)}60%{transform:scale(1.5) rotate(10deg)}100%{transform:scale(1) rotate(0deg)}}

/* BUTTONS */
.btn{border:none;border-radius:14px;padding:12px;font-family:‘Fredoka One’,cursive;font-size:15px;cursor:pointer;transition:transform .15s;display:block;}
.btn:active{transform:scale(.96);}
.btn-pause{background:linear-gradient(135deg,#1565C0,#0D47A1);color:#fff;box-shadow:0 4px 12px rgba(13,71,161,.35);}
.btn-resume{background:linear-gradient(135deg,#D32F2F,#B71C1C);color:#fff;box-shadow:0 4px 12px rgba(183,28,28,.35);}
.btn-reset{background:#ECEFF1;color:var(–muted);font-family:‘Nunito’,sans-serif;font-weight:800;font-size:11px;border-radius:9px;padding:6px 12px;width:auto;display:inline-block;border:none;cursor:pointer;margin:10px 14px 12px;}
.action-row{display:flex;gap:8px;margin-bottom:12px;}

/* PAUSE PANEL */
.pause-panel{padding:12px 14px;background:#E3F2FD;border-top:3px solid #90CAF9;display:none;}
.pause-panel.show{display:block;}
.pause-title{font-family:‘Fredoka One’,cursive;font-size:16px;color:#1565C0;margin-bottom:7px;}
.pause-info{font-size:11px;font-weight:800;color:#0D47A1;background:#BBDEFB;border-radius:9px;padding:7px 10px;margin-bottom:8px;}
.pause-inputs{display:flex;gap:8px;align-items:flex-end;}
.pause-inputs .fg label{color:#1565C0;}
.pause-inputs .fg input{border-color:#90CAF9;}
.pause-inputs .fg input:focus{border-color:#1565C0;}

/* STOP LOG */
.stop-log{padding:8px 14px 12px;background:#FFEBEE;}
.stop-log-title{font-size:10px;font-weight:800;color:#B71C1C;text-transform:uppercase;margin-bottom:6px;}
.stop-entry{display:flex;align-items:center;gap:7px;background:#fff;border-radius:9px;padding:7px 10px;margin-bottom:5px;font-size:11px;font-weight:700;color:#37474F;box-shadow:0 1px 5px rgba(0,0,0,.08);}
.stop-dot{width:9px;height:9px;border-radius:50%;background:#D32F2F;flex-shrink:0;}

/* STOPS ROW */
.stops-row{display:flex;gap:6px;padding:0 14px 12px;background:#FFEBEE;}
.sb{flex:1;padding:9px 4px;border:2px solid #FFCDD2;border-radius:11px;background:#fff;cursor:pointer;font-family:‘Nunito’,sans-serif;font-weight:800;font-size:11px;color:#B71C1C;text-align:center;line-height:1.4;transition:all .2s;}
.sb.done{background:#FFEBEE;border-color:#EF9A9A;color:#B71C1C;}
.sb:active{transform:scale(.95);}

/* ── GAMES ── */
.gg{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:13px;}
.gc{background:#fff;border-radius:16px;padding:14px 10px;text-align:center;box-shadow:0 4px 16px rgba(0,0,0,.15);cursor:pointer;transition:transform .15s;border:3px solid transparent;}
.gc:active{transform:scale(.95);}
.gc .gi{font-size:34px;margin-bottom:5px;}
.gc .gn{font-family:‘Fredoka One’,cursive;font-size:14px;color:#37474F;}
.gc .gd{font-size:9.5px;color:#90A4AE;font-weight:700;margin-top:2px;}
.gc-r1{border-color:#EF5350;background:#FFEBEE;}
.gc-r2{border-color:#FF8F00;background:#FFF3E0;}
.gc-b1{border-color:#42A5F5;background:#E3F2FD;}
.gc-b2{border-color:#7E57C2;background:#EDE7F6;}
.gc-r3{border-color:#EC407A;background:#FCE4EC;}
.gc-b3{border-color:#26C6DA;background:#E0F7FA;}

.ov{display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:100;align-items:flex-end;}
.ov.open{display:flex;}
.panel{background:#fff;border-radius:22px 22px 0 0;padding:16px;width:100%;max-height:88vh;overflow-y:auto;}
.panel-hdr{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;}
.pt{font-family:‘Fredoka One’,cursive;font-size:20px;color:#B71C1C;}
.cb{background:#FFEBEE;border:none;width:30px;height:30px;border-radius:50%;font-size:15px;cursor:pointer;color:#B71C1C;}
.gc2{margin-top:4px;}
.si2{display:flex;align-items:center;gap:9px;padding:10px;background:#FFF5F5;border-radius:11px;margin-bottom:7px;cursor:pointer;border:2px solid transparent;}
.si2:active,.si2.found{background:#FFEBEE;border-color:#EF9A9A;}
.si2.found{text-decoration:line-through;opacity:.6;}
.si2 .sic{font-size:26px;}.si2 .sil{font-weight:700;font-size:13px;color:#37474F;}
.rc{background:linear-gradient(135deg,#FFEBEE,#E3F2FD);border-radius:14px;padding:16px;text-align:center;margin-bottom:11px;border:2px solid #FFCDD2;}
.rq{font-size:14px;font-weight:800;color:#37474F;line-height:1.5;margin-bottom:12px;}
.rab{background:linear-gradient(135deg,#D32F2F,#B71C1C);color:#fff;border:none;border-radius:9px;padding:8px 20px;font-family:‘Fredoka One’,cursive;font-size:14px;cursor:pointer;display:none;}
.rat{display:none;font-size:19px;font-weight:800;color:#B71C1C;margin-top:7px;}
.bn{background:linear-gradient(135deg,#D32F2F,#B71C1C);color:#fff;border:none;border-radius:9px;padding:9px 15px;font-family:‘Fredoka One’,cursive;font-size:14px;cursor:pointer;display:block;width:100%;margin-top:8px;}
.abcg{display:grid;grid-template-columns:repeat(4,1fr);gap:5px;}
.ac{background:#FFF5F5;border-radius:8px;padding:7px 2px;text-align:center;cursor:pointer;border:2px solid transparent;transition:all .2s;}
.ac.found{background:#FFEBEE;border-color:#EF9A9A;}
.ac .al{font-family:‘Fredoka One’,cursive;font-size:18px;color:#D32F2F;}
.ac .aw{font-size:7.5px;font-weight:700;color:#78909C;}

/* SNACKS */
.stip{background:linear-gradient(135deg,#FFEBEE,#FFF3E0);border-radius:12px;padding:11px;margin-bottom:11px;font-size:11.5px;font-weight:700;color:#B71C1C;border-left:4px solid #D32F2F;}
.sng{display:grid;grid-template-columns:1fr 1fr;gap:8px;}
.snc{background:#fff;border-radius:12px;padding:10px;box-shadow:0 3px 10px rgba(183,28,28,.1);display:flex;align-items:center;gap:7px;cursor:pointer;transition:all .2s;border:2px solid transparent;}
.snc:active{border-color:#EF9A9A;}
.snc.given{opacity:.5;}
.sni{font-size:28px;}.snn{font-weight:800;font-size:12px;color:#37474F;}.snno{font-size:9.5px;color:#90A4AE;}.snck{font-size:14px;margin-left:auto;}

/* SONGS */
.song{background:#fff;border-radius:12px;padding:11px;margin-bottom:8px;box-shadow:0 3px 10px rgba(183,28,28,.1);display:flex;align-items:center;gap:8px;cursor:pointer;transition:all .2s;flex-wrap:wrap;border:2px solid transparent;}
.song.playing{background:#FFEBEE;border-color:#EF9A9A;}
.song .soi{font-size:24px;}.song .son{font-weight:800;font-size:12px;color:#37474F;}.song .sot{font-size:9.5px;color:#90A4AE;}.song .sop{margin-left:auto;font-size:18px;}
.lyrics{background:#E3F2FD;border-radius:8px;padding:8px 11px;margin-top:6px;font-size:11px;color:#1565C0;font-weight:700;display:none;line-height:1.8;width:100%;}
.lyrics.show{display:block;}

/* STICKERS */
.sbd{background:#fff;border-radius:14px;min-height:100px;padding:12px;margin-bottom:12px;box-shadow:inset 0 2px 8px rgba(183,28,28,.1);display:flex;flex-wrap:wrap;gap:5px;justify-content:center;align-items:flex-start;border:2px dashed #FFCDD2;}
.es{font-size:34px;animation:popIn .3s cubic-bezier(.68,-.55,.27,1.55);}
@keyframes popIn{0%{transform:scale(0)}100%{transform:scale(1)}}
.spk{display:grid;grid-template-columns:repeat(5,1fr);gap:6px;margin-bottom:12px;}
.so{font-size:28px;text-align:center;padding:5px;background:#fff;border-radius:9px;cursor:pointer;box-shadow:0 2px 8px rgba(183,28,28,.12);border:2px solid transparent;}
.so:active{transform:scale(1.3);}
.so.sel{background:#FFEBEE;border-color:#D32F2F;}
.eb{background:linear-gradient(135deg,#D32F2F,#B71C1C);color:#fff;border:none;border-radius:12px;padding:12px;font-family:‘Fredoka One’,cursive;font-size:16px;cursor:pointer;box-shadow:0 5px 14px rgba(183,28,28,.4);width:100%;}
.eb:active{transform:scale(.95);}
.sd{font-family:‘Fredoka One’,cursive;font-size:18px;color:#D32F2F;margin:5px 0 12px;text-align:center;}

/* WEB DIVIDER */
.web-divider{text-align:center;font-size:13px;letter-spacing:2px;color:#EF9A9A;margin:4px 0 8px;font-weight:800;}
</style>

</head>
