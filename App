<script>
/* ── TABS ── */
function showTab(id,btn){document.querySelectorAll('.sec').forEach(s=>s.classList.remove('active'));document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));document.getElementById(id).classList.add('active');btn.classList.add('active');}

/* ════════ CANVAS MAP ════════ */
const canvas=document.getElementById('mapCanvas');
const ctx=canvas.getContext('2d');
let currentPct=0,jStart=null,jEnd=null,jInterval=null;
let pausedAt=null,totalPausedMs=0,isPaused=false,stops=[];

const ORI_FRAC=0.08, DST_FRAC=0.92;
function oriX(){return canvas.width*ORI_FRAC;}
function dstX(){return canvas.width*DST_FRAC;}
function roadY(){return canvas.height*0.78;}

function resizeCanvas(){
  canvas.width=canvas.parentElement.clientWidth;
  canvas.height=230;
  redraw();
}
window.addEventListener('resize',resizeCanvas);

/* ── DRAW BACKGROUND (Spider-Man cityscape) ── */
function drawBg(){
  const W=canvas.width,H=canvas.height;

  // Night/dusk city sky
  const sky=ctx.createLinearGradient(0,0,0,H*.55);
  sky.addColorStop(0,'#0D1B4B');
  sky.addColorStop(.5,'#1A237E');
  sky.addColorStop(1,'#283593');
  ctx.fillStyle=sky; ctx.fillRect(0,0,W,H*.55);

  // Stars in sky
  ctx.fillStyle='rgba(255,255,255,.8)';
  [[W*.1,H*.08],[W*.22,H*.15],[W*.38,H*.06],[W*.55,H*.12],[W*.7,H*.07],[W*.85,H*.14],[W*.92,H*.05],[W*.3,H*.2],[W*.65,H*.18],[W*.15,H*.25]].forEach(([x,y])=>{
    ctx.beginPath(); ctx.arc(x,y,1.2,0,Math.PI*2); ctx.fill();
  });

  // Moon
  ctx.fillStyle='#FFF9C4';
  ctx.beginPath(); ctx.arc(W*.88,H*.12,16,0,Math.PI*2); ctx.fill();
  ctx.fillStyle='#FFF59D';
  ctx.beginPath(); ctx.arc(W*.88,H*.12,12,0,Math.PI*2); ctx.fill();

  // City buildings (background)
  const buildings=[
    {x:0,     w:W*.08,h:H*.42,win:true},
    {x:W*.07, w:W*.06,h:H*.35,win:true},
    {x:W*.12, w:W*.09,h:H*.48,win:true},
    {x:W*.2,  w:W*.07,h:H*.38,win:true},
    {x:W*.26, w:W*.10,h:H*.44,win:true},
    {x:W*.35, w:W*.08,h:H*.52,win:true},
    {x:W*.42, w:W*.07,h:H*.4, win:true},
    {x:W*.48, w:W*.09,h:H*.46,win:true},
    {x:W*.56, w:W*.08,h:H*.5, win:true},
    {x:W*.63, w:W*.10,h:H*.39,win:true},
    {x:W*.72, w:W*.08,h:H*.45,win:true},
    {x:W*.79, w:W*.07,h:H*.36,win:true},
    {x:W*.85, w:W*.08,h:H*.49,win:true},
    {x:W*.92, w:W*.08,h:H*.41,win:true},
  ];

  buildings.forEach(b=>{
    // Building body
    const bg=ctx.createLinearGradient(b.x,H*.55-b.h,b.x+b.w,H*.55);
    bg.addColorStop(0,'#1A237E'); bg.addColorStop(1,'#283593');
    ctx.fillStyle=bg;
    ctx.fillRect(b.x, H*.55-b.h, b.w, b.h);
    // Building outline
    ctx.strokeStyle='rgba(100,130,255,.3)'; ctx.lineWidth=1;
    ctx.strokeRect(b.x,H*.55-b.h,b.w,b.h);
    // Windows
    if(b.win){
      const cols=Math.floor(b.w/9), rows=Math.floor(b.h/12);
      for(let r=1;r<rows;r++) for(let c=0;c<cols;c++){
        const lit=Math.random()>.4;
        ctx.fillStyle=lit?'rgba(255,236,100,.8)':'rgba(30,50,120,.5)';
        ctx.fillRect(b.x+c*9+2, H*.55-b.h+r*12, 5, 7);
      }
    }
  });

  // Road / ground
  const roadTop=H*.55, roadH=H*.45;
  const gnd=ctx.createLinearGradient(0,roadTop,0,H);
  gnd.addColorStop(0,'#1a1a1a'); gnd.addColorStop(.3,'#212121'); gnd.addColorStop(1,'#111');
  ctx.fillStyle=gnd; ctx.fillRect(0,roadTop,W,roadH);

  // Road surface
  const rY=roadY()-H*.1, rH=H*.26;
  ctx.fillStyle='#2C2C2C'; ctx.fillRect(0,rY,W,rH);
  // Road markings
  ctx.fillStyle='#E0E0E0'; ctx.fillRect(0,rY+2,W,3); ctx.fillRect(0,rY+rH-5,W,3);
  // Dashed center
  ctx.strokeStyle='#FFD54F'; ctx.lineWidth=3; ctx.setLineDash([20,14]);
  ctx.beginPath(); ctx.moveTo(0,rY+rH/2); ctx.lineTo(W,rY+rH/2); ctx.stroke();
  ctx.setLineDash([]);

  // Street glow / reflections
  ctx.fillStyle='rgba(255,213,79,.04)';
  ctx.fillRect(0,rY,W,rH);

  // Web lines across sky (decorative)
  drawWebLines(W,H);
}

function drawWebLines(W,H){
  // Radial web from top-right corner
  const cx=W, cy=0;
  ctx.strokeStyle='rgba(255,255,255,.12)'; ctx.lineWidth=1; ctx.setLineDash([]);
  for(let a=150;a<=230;a+=10){
    const rad=a*Math.PI/180;
    ctx.beginPath();
    ctx.moveTo(cx,cy);
    ctx.lineTo(cx+Math.cos(rad)*W*.7, cy+Math.sin(rad)*H*.7);
    ctx.stroke();
  }
  // Concentric arcs
  ctx.strokeStyle='rgba(255,255,255,.08)';
  [W*.15,W*.28,W*.42,W*.58].forEach(r=>{
    ctx.beginPath(); ctx.arc(cx,cy,r,140*Math.PI/180,240*Math.PI/180); ctx.stroke();
  });

  // Second web from top-left
  const cx2=0, cy2=0;
  ctx.strokeStyle='rgba(255,255,255,.08)'; ctx.lineWidth=1;
  for(let a=-30;a<=60;a+=10){
    const rad=a*Math.PI/180;
    ctx.beginPath();
    ctx.moveTo(cx2,cy2);
    ctx.lineTo(cx2+Math.cos(rad)*W*.5, cy2+Math.sin(rad)*H*.6);
    ctx.stroke();
  }
  [W*.12,W*.22,W*.35].forEach(r=>{
    ctx.beginPath(); ctx.arc(cx2,cy2,r,-40*Math.PI/180,70*Math.PI/180); ctx.stroke();
  });
}

/* ── ROUTE ── */
function drawRoute(){
  const rY=roadY(), ox=oriX(), dx=dstX();
  // Full dashed
  ctx.strokeStyle='rgba(255,255,255,.25)'; ctx.lineWidth=4; ctx.setLineDash([12,8]);
  ctx.beginPath(); ctx.moveTo(ox,rY); ctx.lineTo(dx,rY); ctx.stroke();
  ctx.setLineDash([]);
  // Traveled — red glow
  if(currentPct>0){
    const tx=ox+(dx-ox)*currentPct;
    ctx.shadowColor='#EF5350'; ctx.shadowBlur=10;
    ctx.strokeStyle='#EF5350'; ctx.lineWidth=4;
    ctx.beginPath(); ctx.moveTo(ox,rY); ctx.lineTo(tx,rY); ctx.stroke();
    ctx.shadowBlur=0;
  }
}

/* ── PINS ── */
function drawPin(x,emoji,glow){
  const rY=roadY();
  // Web thread going up
  ctx.strokeStyle='rgba(255,255,255,.5)'; ctx.lineWidth=1.5;
  ctx.beginPath();
  // Slightly wavy thread
  ctx.moveTo(x,rY-6);
  ctx.quadraticCurveTo(x+4,rY-28,x,rY-42);
  ctx.stroke();
  // Glow circle
  ctx.shadowColor=glow; ctx.shadowBlur=16;
  ctx.fillStyle=glow;
  ctx.beginPath(); ctx.arc(x,rY-55,17,0,Math.PI*2); ctx.fill();
  ctx.shadowBlur=0;
  // White ring
  ctx.strokeStyle='white'; ctx.lineWidth=3;
  ctx.beginPath(); ctx.arc(x,rY-55,17,0,Math.PI*2); ctx.stroke();
  // Emoji
  ctx.font='20px sans-serif'; ctx.textAlign='center'; ctx.textBaseline='middle';
  ctx.fillText(emoji,x,rY-54);
}

/* ── SPIDEY CAR ── */
function drawCar(){
  const rY=roadY(), ox=oriX(), dx=dstX();
  const carX=ox+(dx-ox)*currentPct;
  // Web trail
  if(currentPct>0.02){
    const trailX=ox+(dx-ox)*Math.max(0,currentPct-0.06);
    const grad=ctx.createLinearGradient(trailX,rY,carX,rY);
    grad.addColorStop(0,'rgba(211,47,47,0)');
    grad.addColorStop(1,'rgba(211,47,47,.4)');
    ctx.strokeStyle=grad; ctx.lineWidth=8;
    ctx.beginPath(); ctx.moveTo(trailX,rY); ctx.lineTo(carX,rY); ctx.stroke();
  }
  // Shadow
  ctx.fillStyle='rgba(0,0,0,.3)';
  ctx.beginPath(); ctx.ellipse(carX,rY+8,22,5,0,0,Math.PI*2); ctx.fill();
  // Red glow
  ctx.shadowColor='#D32F2F'; ctx.shadowBlur=18;
  ctx.fillStyle='#D32F2F';
  ctx.beginPath(); ctx.arc(carX,rY-2,20,0,Math.PI*2); ctx.fill();
  ctx.shadowBlur=0;
  // Blue ring
  ctx.strokeStyle='#1565C0'; ctx.lineWidth=3;
  ctx.beginPath(); ctx.arc(carX,rY-2,20,0,Math.PI*2); ctx.stroke();
  // Spidey emoji
  ctx.font='22px sans-serif'; ctx.textAlign='center'; ctx.textBaseline='middle';
  ctx.fillText('🕷️',carX,rY-1);
}

/* ── STOP MARKERS ── */
function drawStops(){
  const rY=roadY(), ox=oriX(), dx=dstX();
  stops.forEach(s=>{
    const sx=ox+(dx-ox)*s.pct;
    ctx.shadowColor='#FF8F00'; ctx.shadowBlur=10;
    ctx.fillStyle='#FF8F00'; ctx.strokeStyle='white'; ctx.lineWidth=2;
    ctx.beginPath(); ctx.arc(sx,rY-22,11,0,Math.PI*2); ctx.fill(); ctx.stroke();
    ctx.shadowBlur=0;
    ctx.font='13px sans-serif'; ctx.textAlign='center'; ctx.textBaseline='middle';
    ctx.fillText('☕',sx,rY-22);
    const lbl=s.durationMin+'min';
    ctx.font='bold 9px Nunito,sans-serif';
    const tw=ctx.measureText(lbl).width+10;
    ctx.fillStyle='rgba(255,143,0,.9)';
    rrect(ctx,sx-tw/2,rY-42,tw,13,4); ctx.fill();
    ctx.fillStyle='white'; ctx.textAlign='center';
    ctx.fillText(lbl,sx,rY-36);
  });
}
function rrect(ctx,x,y,w,h,r){ctx.beginPath();ctx.moveTo(x+r,y);ctx.lineTo(x+w-r,y);ctx.arcTo(x+w,y,x+w,y+r,r);ctx.lineTo(x+w,y+h-r);ctx.arcTo(x+w,y+h,x+w-r,y+h,r);ctx.lineTo(x+r,y+h);ctx.arcTo(x,y+h,x,y+h-r,r);ctx.lineTo(x,y+r);ctx.arcTo(x,y,x+r,y,r);ctx.closePath();}

function redraw(){
  if(!ctx) return;
  ctx.clearRect(0,0,canvas.width,canvas.height);
  drawBg();
  drawRoute();
  drawStops();
  drawPin(oriX(),'🏠','#43A047');
  drawPin(dstX(),'🏡','#D32F2F');
  if(jStart) drawCar();
}

/* ════════ JOURNEY ════════ */
function parseT(s){const[h,m]=s.split(':').map(Number);const d=new Date();d.setHours(h,m,0,0);return d;}
function ft(d){return d.toLocaleTimeString('es-CR',{hour:'2-digit',minute:'2-digit',hour12:true});}

function startJourney(){
  jStart=parseT(document.getElementById('departT').value||'07:00');
  jEnd=parseT(document.getElementById('arrivalT').value||'10:00');
  if(jEnd<=jStart) jEnd.setDate(jEnd.getDate()+1);
  totalPausedMs=0; isPaused=false; stops=[]; currentPct=0;
  document.getElementById('dspDepart').textContent=ft(jStart);
  document.getElementById('dspArrival').textContent=ft(jEnd);
  document.getElementById('kidProgress').style.display='block';
  if(jInterval) clearInterval(jInterval);
  updateLive(); jInterval=setInterval(updateLive,15000);
}

function effectiveDur(){return jEnd-jStart-totalPausedMs;}

const spideyMsgs=[
  ['🕷️ ¡La misión comienza!','🚀 ¡Lanzando telaraña!','🕸️ ¡Spidey está en camino!'],
  ['💥 ¡Vamos súper bien!','🦸 ¡Más de la mitad!','⭐ ¡Caleb es un héroe!'],
  ['🏠 ¡Ya casi llegamos!','🎯 ¡Casi en el objetivo!','🔥 ¡Poquito falta!'],
  ['🏆 ¡¡MISIÓN CUMPLIDA!!','🎉 ¡¡LLEGAMOS HÉROES!!','🕷️ ¡¡Spider-Caleb lo logró!!']
];

function updateLive(){
  if(!jStart||!jEnd||isPaused) return;
  const now=new Date();
  const elapsed=(now-jStart)-totalPausedMs;
  currentPct=Math.min(1,Math.max(0,elapsed/effectiveDur()));
  const pct=currentPct*100;
  const leftMs=Math.max(0,jEnd.getTime()+totalPausedMs-now.getTime());
  const lh=Math.floor(leftMs/3600000), lm=Math.round((leftMs%3600000)/60000);
  const ls=lh>0?`${lh}h ${lm}m`:`${lm} min`;

  document.getElementById('progFill').style.width=Math.max(3,pct)+'%';
  document.getElementById('dspNow').textContent=ft(now);
  document.getElementById('dspArrival').textContent=ft(jEnd);

  const mi=pct>=99?3:pct>=66?2:pct>=33?1:0;
  const msgs=spideyMsgs[mi];
  document.getElementById('progLabel').textContent=pct>=99?msgs[0]:`${msgs[Math.floor(now.getSeconds()/20)%msgs.length]} — Faltan ${ls}`;

  [[1,25],[2,50],[3,75],[4,90]].forEach(([n,th])=>document.getElementById('ms'+n).classList.toggle('lit',pct>=th));
  redraw();
}

/* PAUSE / RESUME */
function pauseJourney(){
  if(!jStart||isPaused) return;
  isPaused=true; pausedAt=new Date();
  document.getElementById('btnPause').style.display='none';
  document.getElementById('btnResume').style.display='block';
  document.getElementById('pausePanel').classList.add('show');
  document.getElementById('nowBox').classList.add('paused');
  document.getElementById('nowIcon').textContent='⏸️';
  document.getElementById('pauseInfo').textContent=`⏸️ Paramos a las ${ft(pausedAt)}. ¿A qué hora seguimos?`;
  const sug=new Date(pausedAt.getTime()+30*60000);
  document.getElementById('resumeT').value=`${String(sug.getHours()).padStart(2,'0')}:${String(sug.getMinutes()).padStart(2,'0')}`;
  if(jInterval){clearInterval(jInterval);jInterval=null;}
}
function showResumePanel(){document.getElementById('pausePanel').classList.add('show');}
function resumeJourney(){
  if(!isPaused) return;
  const rTime=parseT(document.getElementById('resumeT').value);
  if(rTime<pausedAt) rTime.setDate(rTime.getDate()+1);
  const dur=rTime-pausedAt;
  totalPausedMs+=dur;
  const pMin=Math.round(dur/60000);
  jEnd=new Date(jEnd.getTime()+dur);
  stops.push({pct:currentPct,pauseTime:pausedAt,resumeTime:rTime,durationMin:pMin});
  updateStopLog();
  isPaused=false; pausedAt=null;
  document.getElementById('btnPause').style.display='block';
  document.getElementById('btnResume').style.display='none';
  document.getElementById('pausePanel').classList.remove('show');
  document.getElementById('nowBox').classList.remove('paused');
  document.getElementById('nowIcon').textContent='🕷️';
  jInterval=setInterval(updateLive,15000); updateLive();
}
function updateStopLog(){
  if(!stops.length) return;
  document.getElementById('stopLog').style.display='block';
  document.getElementById('stopEntries').innerHTML=stops.map((s,i)=>`<div class="stop-entry"><div class="stop-dot"></div><span>Parada ${i+1}: ${ft(s.pauseTime)} → ${ft(s.resumeTime)}</span><span style="margin-left:auto;font-weight:800;color:#D32F2F">${s.durationMin} min</span></div>`).join('');
}

/* STOPS */
function toggleStop(n){const e=document.getElementById('sb'+n);e.classList.toggle('done');e.innerHTML=e.classList.contains('done')?['✅<br>Listo','✅<br>Listo','✅<br>Listo'][n-1]:['🚽<br>Baño','🍔<br>Comida','⛽<br>Gasolina'][n-1];}

/* RESET */
function resetJourney(){
  if(jInterval){clearInterval(jInterval);jInterval=null;}
  jStart=null;jEnd=null;currentPct=0;isPaused=false;pausedAt=null;totalPausedMs=0;stops=[];
  document.getElementById('kidProgress').style.display='none';
  document.getElementById('pausePanel').classList.remove('show');
  document.getElementById('stopLog').style.display='none';
  document.getElementById('stopEntries').innerHTML='';
  document.getElementById('progFill').style.width='3%';
  document.getElementById('btnPause').style.display='block';
  document.getElementById('btnResume').style.display='none';
  document.getElementById('nowIcon').textContent='🕷️';
  document.getElementById('nowBox').classList.remove('paused');
  ['ms1','ms2','ms3','ms4'].forEach(id=>document.getElementById(id).classList.remove('lit'));
  ['sb1','sb2','sb3'].forEach((id,i)=>{const e=document.getElementById(id);e.classList.remove('done');e.innerHTML=['🚽<br>Baño','🍔<br>Comida','⛽<br>Gasolina'][i];});
  redraw();
}

/* GAMES */
const games={
  spy:{title:'👁️ Ojo de Araña',html:()=>[['🌳','Árbol'],['🚗','Carro rojo'],['🏠','Casa'],['☁️','Nube'],['🐄','Vaca'],['🌲','Pino'],['⛽','Gasolinera'],['🚦','Semáforo'],['🐦','Pájaro'],['🌻','Flor'],['🚛','Camión'],['⛰️','Montaña'],['🏪','Tienda'],['🌊','Río'],['🐕','Perro']].map(([i,l])=>`<div class="si2" onclick="this.classList.toggle('found')"><span class="sic">${i}</span><span class="sil">${l}</span><span style="margin-left:auto">⬜</span></div>`).join('')},
  riddle:{title:'🤔 Acertijos de Spidey',html:()=>{const rs=[{q:'Tengo manos pero no puedo aplaudir. ¿Qué soy?',a:'¡Un reloj! ⏰'},{q:'Soy redondo y amarillo, por las mañanas brillo. ¿Quién soy?',a:'¡El sol! ☀️'},{q:'Tengo muchos dientes pero no puedo morder. ¿Qué soy?',a:'¡Un peine! 🪮'},{q:'Cuanto más me secas, más mojado me pongo. ¿Qué soy?',a:'¡Una toalla! 🏖️'},{q:'Soy verde por fuera y roja por dentro, con semillitas negras. ¿Qué soy?',a:'¡Una sandía! 🍉'},{q:'¿De qué color es el traje de Spider-Man?',a:'¡Rojo y azul! 🕷️'},{q:'Soy una fruta amarilla que a los monos les encanta. ¿Quién soy?',a:'¡El banano! 🍌'},{q:'¿Qué lanza el Hombre Araña de sus muñecas?',a:'¡Telarañas! 🕸️'}];const r=rs[Math.floor(Math.random()*rs.length)];return `<div class="rc"><div class="rq">🕷️ ${r.q}</div><button class="rab" id="ridBtn" onclick="showAns('${r.a.replace(/'/g,"\\'")}')">¡Ver respuesta!</button><div class="rat" id="ridAns"></div></div><button class="bn" onclick="openGame('riddle')">Otro acertijo 🔄</button>`;}},
  abc:{title:'🔤 ABC del Camino',html:()=>`<p style="font-weight:800;color:#B71C1C;font-size:12px;margin-bottom:8px">🕸️ Busca algo que empiece con cada letra. Toca cuando la encuentren!</p><div class="abcg">${[['A','Árbol'],['B','Bus'],['C','Casa'],['D','Dueño'],['E','Escuela'],['F','Flor'],['G','Gasolinera'],['H','Hombre'],['I','Iglesia'],['J','Jardín'],['L','Lago'],['M','Montaña'],['N','Nube'],['O','Oveja'],['P','Puente'],['R','Río'],['S','Señal'],['T','Tractor'],['V','Vaca'],['Z','Zopilote']].map(([l,h])=>`<div class="ac" onclick="this.classList.toggle('found')"><div class="al">${l}</div><div class="aw">${h}</div></div>`).join('')}</div>`},
  story:{title:'📖 Aventura Spider-Man',html:()=>{const ss=['Spider-Man necesitaba ayuda de Caleb porque el Duende Verde...','En la ciudad de Nueva York, Caleb encontró una telaraña mágica que...','El Hombre Araña y Caleb volaban por los edificios cuando de repente...','Un villano muy malo robó el helado de todos. ¡Caleb y Spidey decidieron...','Spider-Man le dijo a Caleb: "eres el mejor compañero porque..."'];const s=ss[Math.floor(Math.random()*ss.length)];return `<div class="rc"><div class="rq">🕷️ <em>"${s}"</em></div></div><p style="font-size:11px;font-weight:800;color:#546E7A;margin:8px 0">👨‍👦 Papá dice una parte, Caleb dice la siguiente. ¡Sin respuesta incorrecta! 🦸</p><button class="bn" onclick="openGame('story')">Nueva aventura 🔄</button>`;}},
  colors:{title:'🌈 Caza Colores',html:()=>`<p style="font-weight:800;color:#B71C1C;font-size:12px;margin-bottom:8px">¡El primero en ver algo de ese color gana un punto! 🏆</p>${[['🔴','Rojo','¡El color de Spidey!'],['🔵','Azul','¡También de Spidey!'],['🟡','Amarillo','Taxi, flor, señal'],['🟢','Verde','Árbol, hierba, carro'],['⚪','Blanco','Nube, pared, carro'],['🟠','Naranja','Cono, flor, fruta']].map(([i,c,h])=>`<div class="si2" onclick="this.classList.toggle('found')"><span class="sic">${i}</span><div><div style="font-weight:800;font-size:13px;color:#37474F">${c}</div><div style="font-size:10px;color:#90A4AE">${h}</div></div></div>`).join('')}`},
  cars:{title:'🚗 Cuenta Carros',html:()=>`<p style="font-weight:800;color:#B71C1C;font-size:12px;margin-bottom:8px">Cada quien cuenta carros de un color. ¿Quién llega a 10 primero? 🏁</p><div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:8px">${[['🔴','Rojos','#EF5350'],['🔵','Azules','#42A5F5'],['⚫','Negros','#546E7A'],['⚪','Blancos','#90A4AE']].map(([i,l,c])=>`<div style="background:#fff;border-radius:11px;padding:10px;text-align:center;box-shadow:0 3px 8px rgba(0,0,0,.07)"><div style="font-size:25px">${i}</div><div style="font-family:'Fredoka One',cursive;font-size:12px;color:${c}">${l}</div><div style="font-family:'Fredoka One',cursive;font-size:29px;color:#37474F" id="ct_${l}">0</div><div style="display:flex;gap:5px;justify-content:center;margin-top:3px"><button onclick="cc('${l}',-1)" style="background:#ECEFF1;border:none;border-radius:6px;width:26px;height:26px;font-size:14px;cursor:pointer">−</button><button onclick="cc('${l}',1)" style="background:${c};color:#fff;border:none;border-radius:6px;width:26px;height:26px;font-size:14px;cursor:pointer">+</button></div></div>`).join('')}</div><button class="bn" onclick="resetCC()">Reiniciar 🔄</button>`}
};
const carCts={};
function cc(l,d){carCts[l]=Math.max(0,(carCts[l]||0)+d);const e=document.getElementById('ct_'+l);if(e)e.textContent=carCts[l];if(carCts[l]>=10)setTimeout(()=>alert(`🎉 ¡${l} llegó a 10! ¡Eres un héroe como Spidey!`),100);}
function resetCC(){['Rojos','Azules','Negros','Blancos'].forEach(l=>{carCts[l]=0;const e=document.getElementById('ct_'+l);if(e)e.textContent=0;});}
function openGame(id){const g=games[id];document.getElementById('gT').textContent=g.title;document.getElementById('gC').innerHTML=g.html();document.getElementById('gameOv').classList.add('open');if(id==='riddle')setTimeout(()=>{const b=document.getElementById('ridBtn');if(b)b.style.display='inline-block';},1500);}
function closeGame(){document.getElementById('gameOv').classList.remove('open');}
function showAns(a){const b=document.getElementById('ridBtn');if(b)b.style.display='none';const e=document.getElementById('ridAns');if(e){e.textContent=a;e.style.display='block';}}

/* SNACKS */
function giveSnack(c){c.classList.toggle('given');c.querySelector('.snck').textContent=c.classList.contains('given')?'✅':'⬜';}

/* SONGS */
function toggleSong(item){const ly=item.querySelector('.lyrics');const was=ly.classList.contains('show');document.querySelectorAll('.lyrics').forEach(l=>l.classList.remove('show'));document.querySelectorAll('.song').forEach(s=>s.classList.remove('playing'));if(!was){ly.classList.add('show');item.classList.add('playing');}}

/* STICKERS */
let curS='🕷️',sCnt=0;
function selS(el){document.querySelectorAll('.so').forEach(s=>s.classList.remove('sel'));el.classList.add('sel');curS=el.textContent;}
function earnSticker(){
  const b=document.getElementById('sBoard');
  if(b.querySelector('div[style]'))b.innerHTML='';
  const s=document.createElement('span');s.className='es';s.textContent=curS;b.appendChild(s);
  sCnt++;
  document.getElementById('sScore').textContent=`${sCnt} insignia${sCnt!==1?'s':''} ganada${sCnt!==1?'s':''} 🕷️`;
  if(sCnt===5)setTimeout(()=>alert('🕷️🏆 ¡¡CALEB ES EL NUEVO SPIDER-MAN!! ¡5 insignias! 🏆🕷️'),300);
}

/* INIT */
resizeCanvas();
</script>

</body>
</html>
